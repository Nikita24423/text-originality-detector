# =============================================================================
# text-originality-detector — пример конфигурации
# Скопируйте в .env и заполните свои значения
# =============================================================================

DATABASE_URL=postgresql://postgres:PASSWORD@localhost:5436/nikita2

QDRANT_ENABLED=0
QDRANT_HOST=127.0.0.1
QDRANT_PORT=6333
QDRANT_COLLECTION=corpus_bge_m3
RUBERT_COLLECTION=corpus_rubert

API_HOST=127.0.0.1
API_PORT=8001
API_WORKERS=4
ML_WORKERS=1

EMBED_MODEL=BAAI/bge-m3
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
AI_MODEL=sberbank-ai/rugpt3small_based_on_gpt2
RUBERT_MODEL=cointegrated/rubert-tiny2

FAST_MODE=1
ENABLE_AI=0
ENABLE_RERANKER=0
MAX_CHUNKS=60
ENCODE_BATCH_SIZE=16

COPY_THRESHOLD=0.75
DEEP_SEMANTIC_THRESHOLD=0.82
DEEP_RERANK_THRESHOLD=0.65
CHUNK_SIZE=1000
CHUNK_OVERLAP=50
SEMANTIC_TOP_K=2

MAX_FILE_SIZE=12582912

OMP_NUM_THREADS=1
MKL_NUM_THREADS=1
TOKENIZERS_PARALLELISM=false
